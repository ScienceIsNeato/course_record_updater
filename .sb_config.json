{
  "version": "1.0",
  "custom_gates": [
    {
      "name": "frontend-sanity",
      "description": "LoopCloser frontend HTML asset API and JS syntax sanity",
      "category": "overconfidence",
      "command": "bash -lc './scripts/run_frontend_sanity.sh'",
      "level": "swab",
      "timeout": 45
    },
    {
      "name": "smoke",
      "description": "LoopCloser smoke suite",
      "category": "overconfidence",
      "command": "bash -lc './scripts/run_smoke.sh'",
      "level": "scour",
      "timeout": 90
    },
    {
      "name": "e2e",
      "description": "LoopCloser end-to-end suite",
      "category": "overconfidence",
      "command": "bash -lc './scripts/run_uat.sh'",
      "level": "scour",
      "timeout": 1800
    }
  ],
  "overconfidence": {
    "enabled": true,
    "gates": {
      "untested-code.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "test_dirs": [
          "tests/unit",
          "tests/integration"
        ],
        "timeout": 300
      },
      "coverage-gaps.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "threshold": 80
      },
      "missing-annotations.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "strict_typing": true,
        "include_dirs": [
          "src",
          "scripts",
          "tests"
        ]
      },
      "type-blindness.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "strict": true
      },
      "untested-code.js": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "test_command": "npm test"
      },
      "coverage-gaps.js": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "threshold": 80
      },
      "type-blindness.js": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "tsconfig": "tsconfig.json"
      },
      "coverage-gaps.dart": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "threshold": 80
      }
    }
  },
  "deceptiveness": {
    "enabled": true,
    "gates": {
      "bogus-tests.js": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "max_allowed": 0,
        "exclude_dirs": [
          ".specstory"
        ]
      },
      "hand-wavy-tests.js": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "additional_assert_functions": [],
        "exclude_dirs": [
          ".specstory"
        ],
        "max_violations": 0
      },
      "bogus-tests.dart": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "max_allowed": 0
      },
      "bogus-tests.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "test_dirs": [
          "tests"
        ],
        "exclude_patterns": [
          "conftest.py"
        ],
        "min_test_statements": 1,
        "short_test_severity": "fail"
      },
      "debugger-artifacts": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "exclude_dirs": [
          ".specstory"
        ],
        "max_files": 50000
      },
      "gate-dodging": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "base_ref": ""
      }
    }
  },
  "laziness": {
    "enabled": true,
    "gates": {
      "sloppy-formatting.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "line_length": 88
      },
      "sloppy-formatting.js": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": "config/.eslintrc.json",
        "npm_install_flags": []
      },
      "sloppy-frontend.js": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "frontend_dirs": []
      },
      "generated-artifacts.dart": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "exclude_paths": []
      },
      "complexity-creep.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "max_rank": "C",
        "max_complexity": 15,
        "src_dirs": [
          "src",
          "scripts",
          "tests"
        ]
      },
      "dead-code.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "min_confidence": 80,
        "exclude_patterns": [
          "**/.specstory/**",
          "**/.git/**",
          "**/.mypy_cache/**",
          "**/.pytest_cache/**",
          "**/.ruff_cache/**",
          "**/htmlcov/**",
          "**/coverage/**",
          "**/logs/**",
          "**/archive/**",
          "**/research/**",
          "**/data/**",
          "**/.slopmop/**",
          "**/.agent/**",
          "**/.claude/**",
          "**/.vscode/**",
          "**/venv/**",
          "**/.venv/**",
          "**/node_modules/**",
          "**/ephemeral/**",
          "**/test_*",
          "**/tests/**",
          "**/conftest.py",
          "**/*.egg-info/**",
          "**/build/**",
          "**/dist/**",
          "**/cursor-rules/**"
        ],
        "src_dirs": [
          "src",
          "scripts"
        ],
        "whitelist_file": ""
      },
      "silenced-gates": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null
      },
      "broken-templates.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "templates_dir": null
      }
    }
  },
  "myopia": {
    "enabled": true,
    "gates": {
      "just-this-once.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null
      },
      "dependency-risk.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": ".secrets.baseline",
        "scanners": [
          "bandit",
          "semgrep",
          "detect-secrets"
        ],
        "pip_audit_ignore_vulns": [
          "GHSA-5239-wwwm-4pmq"
        ],
        "exclude_dirs": [
          ".specstory",
          "venv",
          ".venv",
          "node_modules",
          "cursor-rules",
          "archive",
          "build",
          "coverage",
          "htmlcov",
          "research",
          "docs",
          "demos",
          "templates",
          "static",
          "flask_session",
          "data",
          ".envrc.template",
          ".github",
          ".mypy_cache",
          ".pytest_cache",
          ".ruff_cache",
          ".slopmop",
          "secrets.baseline",
          "logs",
          "tests",
          "*/.venv",
          "*/venv"
        ],
        "bandit_config_file": null
      },
      "vulnerability-blindness.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": ".secrets.baseline",
        "scanners": [
          "bandit",
          "semgrep",
          "detect-secrets"
        ],
        "exclude_dirs": [
          ".specstory",
          "venv",
          ".venv",
          "node_modules",
          "cursor-rules",
          "archive",
          "build",
          "coverage",
          "htmlcov",
          "research",
          "docs",
          "demos",
          "templates",
          "static",
          "flask_session",
          "data",
          ".mypy_cache",
          ".pytest_cache",
          ".ruff_cache",
          ".slopmop",
          "secrets.baseline",
          "logs",
          "tests",
          "*/.venv",
          "*/venv"
        ],
        "bandit_config_file": null
      },
      "source-duplication": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "threshold": 5,
        "include_dirs": [
          "src",
          "tests",
          "scripts",
          "static",
          "templates"
        ],
        "min_tokens": 50,
        "min_lines": 5,
        "exclude_dirs": [
          ".specstory",
          ".git",
          ".mypy_cache",
          ".pytest_cache",
          ".ruff_cache",
          ".slopmop",
          ".agent",
          ".claude",
          ".vscode",
          "venv",
          ".venv",
          "node_modules",
          "cursor-rules",
          "coverage",
          "htmlcov",
          "build",
          "logs",
          "archive",
          "research",
          "data",
          "flask_session"
        ]
      },
      "string-duplication.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "threshold": 2,
        "min_file_count": 1,
        "min_length": 8,
        "min_words": 3,
        "include_patterns": [
          "**/*.py"
        ],
        "ignore_patterns": [
          "**/.specstory/**",
          "**/htmlcov/**",
          "**/coverage/**",
          "**/build/**",
          "**/logs/**",
          "**/archive/**",
          "**/research/**",
          "**/data/**",
          "**/.slopmop/**",
          "**/.mypy_cache/**",
          "**/.pytest_cache/**",
          "**/.ruff_cache/**",
          "**/.agent/**",
          "**/.claude/**",
          "**/.vscode/**",
          "**/node_modules/**",
          "**/.venv/**",
          "**/venv/**",
          "**/__pycache__/**",
          "**/.git/**",
          "**/*.egg-info/**",
          "**/test_*",
          "**/tests/**",
          "**/conftest.py"
        ]
      },
      "code-sprawl": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "max_file_lines": 1000,
        "max_function_lines": 100,
        "include_dirs": [
          "src",
          "tests",
          "scripts",
          "static",
          "templates"
        ],
        "exclude_dirs": [
          ".specstory",
          ".git",
          ".mypy_cache",
          ".pytest_cache",
          ".ruff_cache",
          ".slopmop",
          ".agent",
          ".claude",
          ".vscode",
          "venv",
          ".venv",
          "node_modules",
          "cursor-rules",
          "coverage",
          "htmlcov",
          "build",
          "logs",
          "archive",
          "research",
          "data",
          "flask_session"
        ],
        "extensions": []
      },
      "ignored-feedback": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "fail_on_unresolved": false
      },
      "walk-forward": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null
      }
    }
  },
  "disabled_gates": [],
  "swabbing_time": 30
}